rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Save validation helper
    function isValidSave(data) {
      return data.userId == request.auth.uid
        && data.displayName is string
        && data.displayName.size() <= 100
        && data.posX is number
        && data.posY is number
        && data.hp is number
        && data.maxHp is number
        && data.mana is number
        && data.maxMana is number
        && data.level is number
        && data.exp is number
        && data.interactedNPCs is list
        && data.interactedNPCs.size() <= 100
        && data.inventory is list
        && data.inventory.size() <= 100;
    }

    // Match block for the Saves collection
    match /saves/{userId} {
      allow get: if isEmailVerified() && userId == request.auth.uid;
      
      allow create: if isEmailVerified() 
        && isValidId(userId) 
        && userId == request.auth.uid 
        && isValidSave(incoming())
        && incoming().keys().hasAll(['userId', 'displayName', 'posX', 'posY', 'hp', 'maxHp', 'mana', 'maxMana', 'level', 'exp', 'interactedNPCs', 'inventory', 'updatedAt'])
        && incoming().keys().size() == 13
        && incoming().updatedAt == request.time;
        
      allow update: if isEmailVerified() 
        && isValidId(userId) 
        && userId == request.auth.uid 
        && isValidSave(incoming())
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time;
        
      allow delete: if isEmailVerified() && userId == request.auth.uid;
    }
  }
}
